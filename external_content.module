<?php

/**
 * @file
 * External Content module.
 */

use Drupal\external_content\ExternalContentJsonApi;

/**
 * Implements hook_theme().
 */
function external_content_theme($existing, $type, $theme, $path) {

  $items = [
    'external_content' => [
      'variables' => [
        'doc' => NULL,
        'link' => NULL,
        'response' => NULL,
        'source_id' => NULL,
        'source' => NULL,
      ],
      'template' => 'external-content',
    ],
  ];

  return $items;
}

/**
 * Implements hook_theme_suggestions_HOOK().
 */
function external_content_theme_suggestions_external_content(array $variables) {
  /** @var \Drupal\external_content\Entity\ExternalContentSource $source */
  $source = $variables['source'];
  $suggestions = [
    'external_content',
    'external_content__' . $source->getId(),
    'external_content__' . $source->getType(),
  ];
  return $suggestions;
}

/**
 * Implements hook_preprocess_HOOK().
 */
function template_preprocess_external_content(&$variables) {
  /** @var \Drupal\external_content\Entity\ExternalContentSource $source */
  $source = $variables['source'];
  $plugin_id = $source->getType();

  $variables['attributes']['class'] = [
    'external-content',
    'external-content--' . $source->id(),
    'external-content--' . $plugin_id,
  ];
}
